{
  "name": "nurse-simulator",
  "version": "1.1.0",
  "description": "간호 국시 시뮬레이터 — 임상 의사결정 + 8과목 트레이닝 + 모의고사",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "nursing",
    "simulation",
    "education",
    "korea"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/tests/questions.test.js"]
      },
      {
        "displayName": "integration",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/tests/integration.test.js"]
      }
    ]
  }
}

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "alwaysStrict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": [
    "script.js",
    "content.js",
    "nclex-content.js",
    "questions.js",
    "images/image-map.js"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "www",
    "build",
    "preview.html"
  ]
}
